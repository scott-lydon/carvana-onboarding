{
  "name": "carvana-onboarding-prototype",
  "version": "0.0.1",
  "private": true,
  "description": "Working web prototype of a graceful-degradation, OCR-augmented recovery layer for Carvana's sell/buy onboarding entry step.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env.local server/index.ts",
    "dev:all": "concurrently -n client,server -c blue,magenta \"npm:dev\" \"npm:dev:server\"",
    "build": "tsc --noEmit && vite build",
    "build:server": "rm -rf dist-server && tsc --project server/tsconfig.json",
    "start": "node --env-file-if-exists=.env.local dist-server/server/index.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit --project server/tsconfig.json",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:property": "vitest run tests/property --passWithNoTests",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run lint && npm run test && npm run test:property && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "fast-check": "^3.22.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
