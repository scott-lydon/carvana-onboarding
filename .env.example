# Anthropic — v2 chatbot orchestrator AND vision OCR (one vendor, one key).
# Sign up: https://console.anthropic.com/settings/keys
# Pricing: pay-as-you-go; ~$3 per million input tokens for Sonnet 4.5
# Used by: /api/chat (slice A) and /api/ocr/recognize (slice B).
# WITHOUT this key, the chat endpoint returns 503 configuration_missing
# with the signup URL embedded in the response.
ANTHROPIC_API_KEY=

# CarsXE — primary plate vendor (self-service signup, sandbox tier free)
# Sign up: https://api.carsxe.com/register
# Sandbox: 100 API calls lifetime, no card required
CARSXE_API_KEY=
# Optional override; defaults to https://api.carsxe.com
CARSXE_BASE_URL=

# VinAudit — secondary plate vendor (B2B sales-issued sandbox, pending)
# Request: https://www.vinaudit.com/b2b-vehicle-data-products
VINAUDIT_API_KEY=
VINAUDIT_BASE_URL=

# DataOne Software (deferred under v2, kept for v1 reference)
DATAONE_API_KEY=
DATAONE_CLIENT_ID=

# Optional: Sentry for production error tracking
SENTRY_DSN=
