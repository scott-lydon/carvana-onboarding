# CarsXE — primary plate vendor (self-service signup, sandbox tier free)
# Sign up: https://api.carsxe.com/register
# Sandbox: 100 API calls lifetime, no card required
CARSXE_API_KEY=
# Optional override; defaults to https://api.carsxe.com
CARSXE_BASE_URL=

# VinAudit — secondary plate vendor (B2B sales-issued sandbox, pending)
# Request: https://www.vinaudit.com/b2b-vehicle-data-products
VINAUDIT_API_KEY=
VINAUDIT_BASE_URL=

# DataOne Software (enterprise fallback, slice 2)
DATAONE_API_KEY=
DATAONE_CLIENT_ID=

# Google Cloud Vision (web OCR, slice 4)
# GOOGLE_APPLICATION_CREDENTIALS points at a JSON service-account file
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: Sentry for production error tracking
SENTRY_DSN=
