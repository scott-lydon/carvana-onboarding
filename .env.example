# Carfax QuickVIN Plus (primary plate vendor)
# Get sandbox credentials from your Carfax dealer account dashboard
CARFAX_API_KEY=
CARFAX_DEALER_ID=

# DataOne Software (fallback plate vendor)
# Enterprise tier; request sandbox credentials from sales
DATAONE_API_KEY=
DATAONE_CLIENT_ID=

# Google Cloud Vision (web OCR)
# Service account JSON, base64-encoded
GOOGLE_CLOUD_VISION_KEY=

# Optional: Sentry for production error tracking
SENTRY_DSN=
